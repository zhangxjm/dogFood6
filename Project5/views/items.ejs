<div class="section">
    <div class="toolbar">
        <h2>📦 福利物资管理</h2>
        <div>
            <input type="text" id="searchBox" class="search-box" placeholder="搜索物资名称...">
            <button class="btn btn-green" onclick="openModal('addItemModal')">+ 新增物资</button>
        </div>
    </div>

    <% if (items.length > 0) { %>
        <table class="table data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>物资名称</th>
                    <th>分类</th>
                    <th>库存</th>
                    <th>单位</th>
                    <th>描述</th>
                    <th>创建时间</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                <% items.forEach(function(item) { %>
                    <tr>
                        <td><%= item.id %></td>
                        <td><%= item.name %></td>
                        <td><%= item.category %></td>
                        <td><%= item.stock %></td>
                        <td><%= item.unit %></td>
                        <td><%= item.description %></td>
                        <td><%= item.created_at %></td>
                        <td>
                            <button class="btn btn-orange" onclick="editItem(<%= item.id %>, '<%= item.name %>', '<%= item.category %>', <%= item.stock %>, '<%= item.unit %>', '<%= item.description %>')">编辑</button>
                            <form id="deleteItem<%= item.id %>" action="/items/<%= item.id %>" method="POST" style="display: inline;">
                                <input type="hidden" name="_method" value="DELETE">
                                <button type="button" class="btn btn-red" onclick="confirmDelete('deleteItem<%= item.id %>')">删除</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } else { %>
        <div class="empty-state">
            <p>暂无物资数据，点击上方按钮添加新物资</p>
        </div>
    <% } %>
</div>

<div id="addItemModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>新增物资</h3>
            <button class="close-btn" onclick="closeModal('addItemModal')">&times;</button>
        </div>
        <form action="/items" method="POST">
            <div class="form-group">
                <label>物资名称</label>
                <input type="text" name="name" required>
            </div>
            <div class="form-group">
                <label>分类</label>
                <input type="text" name="category" placeholder="如：节日礼品、生日福利等">
            </div>
            <div class="form-group">
                <label>库存数量</label>
                <input type="number" name="stock" value="0" min="0">
            </div>
            <div class="form-group">
                <label>单位</label>
                <input type="text" name="unit" placeholder="如：盒、份、张等">
            </div>
            <div class="form-group">
                <label>描述</label>
                <textarea name="description" rows="3"></textarea>
            </div>
            <div class="actions">
                <button type="button" class="btn" onclick="closeModal('addItemModal')">取消</button>
                <button type="submit" class="btn btn-green">确认添加</button>
            </div>
        </form>
    </div>
</div>

<div id="editItemModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>编辑物资</h3>
            <button class="close-btn" onclick="closeModal('editItemModal')">&times;</button>
        </div>
        <form id="editItemForm" action="" method="POST">
            <input type="hidden" name="_method" value="PUT">
            <input type="hidden" id="edit_item_id" name="id">
            <div class="form-group">
                <label>物资名称</label>
                <input type="text" id="edit_item_name" name="name" required>
            </div>
            <div class="form-group">
                <label>分类</label>
                <input type="text" id="edit_item_category" name="category">
            </div>
            <div class="form-group">
                <label>库存数量</label>
                <input type="number" id="edit_item_stock" name="stock" min="0">
            </div>
            <div class="form-group">
                <label>单位</label>
                <input type="text" id="edit_item_unit" name="unit">
            </div>
            <div class="form-group">
                <label>描述</label>
                <textarea id="edit_item_description" name="description" rows="3"></textarea>
            </div>
            <div class="actions">
                <button type="button" class="btn" onclick="closeModal('editItemModal')">取消</button>
                <button type="submit" class="btn btn-orange">保存修改</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.getElementById('editItemForm').addEventListener('submit', function(e) {
        const id = document.getElementById('edit_item_id').value;
        this.action = '/items/' + id;
    });
</script>
