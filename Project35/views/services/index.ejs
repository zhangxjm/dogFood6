<%- include('../partials/header') %>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="fa fa-list me-2 text-primary"></i>服务类型
        </h2>
    </div>

    <div class="row">
        <% services.forEach(function(service) { %>
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body text-center">
                        <div class="display-3 mb-3 text-primary">
                            <i class="fa <%= service.icon || 'fa-wrench' %>"></i>
                        </div>
                        <h5 class="card-title"><%= service.name %></h5>
                        <span class="badge bg-info mb-2"><%= service.category %></span>
                        <p class="card-text text-muted"><%= service.description %></p>
                        <p class="text-primary fw-bold">起步价：¥<%= service.base_price %></p>
                    </div>
                    <div class="card-footer bg-white">
                        <div class="d-grid">
                            <a href="/orders/new?service_id=<%= service.id %>" class="btn btn-primary btn-sm">
                                <i class="fa fa-calendar-plus-o me-2"></i>立即预约
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<%- include('../partials/footer') %>
