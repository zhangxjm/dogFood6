<%- include('../partials/header') %>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">订单详情</h4>
                    <span class="badge 
                        <%= order.status === 'pending' ? 'bg-secondary' : '' %>
                        <%= order.status === 'assigned' ? 'bg-info' : '' %>
                        <%= order.status === 'processing' ? 'bg-warning text-dark' : '' %>
                        <%= order.status === 'completed' ? 'bg-success' : '' %>
                        status-badge
                    ">
                        <%= statusMap[order.status] %>
                    </span>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <p class="text-muted mb-1">订单编号</p>
                            <h5><%= order.order_no %></h5>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted mb-1">创建时间</p>
                            <h5><%= order.created_at %></h5>
                        </div>
                    </div>

                    <hr>

                    <h5 class="mb-3">服务信息</h5>
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <p class="mb-1"><strong>服务类型：</strong><%= order.service_name %></p>
                            <p class="mb-1"><strong>服务描述：</strong><%= order.service_description %></p>
                            <p class="mb-1"><strong>预约时间：</strong><%= order.appointment_date %> <%= order.appointment_time %></p>
                            <p class="mb-0"><strong>故障描述：</strong><%= order.problem_description || '无' %></p>
                        </div>
                    </div>

                    <hr>

                    <h5 class="mb-3">客户信息</h5>
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <p class="mb-1"><strong>客户姓名：</strong><%= order.customer_name %></p>
                            <p class="mb-1"><strong>联系电话：</strong><%= order.customer_phone %></p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-0"><strong>服务地址：</strong><%= order.customer_address %></p>
                        </div>
                    </div>

                    <% if (order.technician_name) { %>
                        <hr>
                        <h5 class="mb-3">技师信息</h5>
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <p class="mb-1"><strong>技师姓名：</strong><%= order.technician_name %></p>
                                <p class="mb-1"><strong>联系电话：</strong><%= order.technician_phone %></p>
                            </div>
                            <div class="col-md-6">
                                <p class="mb-0"><strong>专业领域：</strong><%= order.technician_specialty %></p>
                            </div>
                        </div>
                    <% } %>

                    <% if (order.status === 'completed') { %>
                        <hr>
                        <h5 class="mb-3">维修完成信息</h5>
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <p class="mb-1"><strong>完成时间：</strong><%= order.completed_at %></p>
                                <p class="mb-1"><strong>维修费用：</strong><span class="text-primary fw-bold">¥<%= order.total_price %></span></p>
                            </div>
                            <div class="col-md-6">
                                <p class="mb-0"><strong>维修备注：</strong><%= order.remark || '无' %></p>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">操作</h5>
                </div>
                <div class="card-body">
                    <% if (order.status === 'pending') { %>
                        <form action="/orders/<%= order.id %>/assign" method="POST" class="mb-2">
                            <button type="submit" class="btn btn-info w-100 text-white">
                                <i class="fa fa-user-plus me-2"></i>派单
                            </button>
                        </form>
                    <% } %>

                    <% if (order.status === 'assigned') { %>
                        <form action="/orders/<%= order.id %>/start" method="POST" class="mb-2">
                            <button type="submit" class="btn btn-warning w-100">
                                <i class="fa fa-play me-2"></i>开始维修
                            </button>
                        </form>
                    <% } %>

                    <% if (order.status === 'processing') { %>
                        <button type="button" class="btn btn-success w-100 mb-2" data-bs-toggle="modal" data-bs-target="#completeModal">
                            <i class="fa fa-check me-2"></i>完成维修
                        </button>
                    <% } %>

                    <% if (order.status !== 'completed') { %>
                        <div class="d-grid gap-2">
                            <a href="/orders" class="btn btn-outline-secondary">
                                <i class="fa fa-arrow-left me-2"></i>返回列表
                            </a>
                        </div>
                    <% } else { %>
                        <div class="d-grid gap-2">
                            <a href="/orders/new" class="btn btn-primary">
                                <i class="fa fa-plus me-2"></i>新建预约
                            </a>
                            <a href="/orders" class="btn btn-outline-secondary">
                                <i class="fa fa-arrow-left me-2"></i>返回列表
                            </a>
                        </div>
                    <% } %>

                    <% if (order.status !== 'completed') { %>
                        <hr>
                        <form action="/orders/<%= order.id %>?_method=DELETE" method="POST" onsubmit="return confirmDelete()">
                            <button type="submit" class="btn btn-outline-danger w-100">
                                <i class="fa fa-trash me-2"></i>删除订单
                            </button>
                        </form>
                    <% } %>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">订单进度</h5>
                </div>
                <div class="card-body">
                    <div class="steps">
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center" style="width: 30px; height: 30px;">
                                <i class="fa fa-check"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <p class="mb-0 fw-bold">订单创建</p>
                                <small class="text-muted">订单已提交</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-circle <%= ['assigned', 'processing', 'completed'].includes(order.status) ? 'bg-success' : 'bg-secondary' %> text-white d-flex align-items-center justify-content-center" style="width: 30px; height: 30px;">
                                <i class="fa fa-user"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <p class="mb-0 fw-bold">技师派单</p>
                                <small class="text-muted">分配专业技师</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-circle <%= ['processing', 'completed'].includes(order.status) ? 'bg-success' : 'bg-secondary' %> text-white d-flex align-items-center justify-content-center" style="width: 30px; height: 30px;">
                                <i class="fa fa-wrench"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <p class="mb-0 fw-bold">维修中</p>
                                <small class="text-muted">技师上门维修</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle <%= order.status === 'completed' ? 'bg-success' : 'bg-secondary' %> text-white d-flex align-items-center justify-content-center" style="width: 30px; height: 30px;">
                                <i class="fa fa-check-circle"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <p class="mb-0 fw-bold">已完成</p>
                                <small class="text-muted">维修完成确认</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<% if (order.status === 'processing') { %>
    <div class="modal fade" id="completeModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/orders/<%= order.id %>/complete" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title">确认维修完成</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">实际维修费用</label>
                            <input type="number" name="actual_price" class="form-control" value="<%= order.total_price %>" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">维修备注</label>
                            <textarea name="remark" class="form-control" rows="3" placeholder="请填写维修情况说明"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                        <button type="submit" class="btn btn-success">
                            <i class="fa fa-check me-2"></i>确认完成
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
<% } %>

<%- include('../partials/footer') %>
